# Secrets and local environment — MUST never enter the build context
.env
.env.*

# Version control and CI metadata
.git
.gitignore
.github

# IDE and editor state
.idea
.vscode
*.swp
*.swo

# Build artifacts and local outputs
bin/
/verophi
coverage.out
t.json
